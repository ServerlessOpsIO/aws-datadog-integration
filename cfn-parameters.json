{
    "AwsOamSinkArn": $secrets.AWS_OAM_SINK_ARN,
    "TargetOUs": $secrets.AWS_ORG_ROOT_ID,
    "TargetRegions": "us-east-1",
    "DatadogApiKey": $secrets.DATADOG_API_KEY,
    "DatadogAppKey": $secrets.DATADOG_APP_KEY,
    "DataDogLogsDestinationArn": $secrets.DATADOG_LOGS_DESTINATION_ARN,
    "DatadogSite": "us5.datadoghq.com",
    "DatadogTemplateUrl": "https://datadog-cloudformation-template.s3.amazonaws.com/aws/v4.1.3/main_organizations.yaml",
    "DisableMetricCollection": "true",
    "CrossAccountSharingPolicy": "CloudWatch-core-permissions"
}